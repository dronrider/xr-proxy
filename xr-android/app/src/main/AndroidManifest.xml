<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />
    <!-- location FGS type: пока туннель работает, держит foreground-доступ к гео,
         чтобы читать SSID доверенной сети в фоне (XR-023). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- APK self-update (LLD-12): hand the downloaded APK to the system
         installer via PackageInstaller. If not granted/revoked, the system
         shows its "allow install from this source" gate — we never crash. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Своя папка хранения шары (XR-043): движок синка пишет реальный FS-путь,
         поэтому пользовательская папка на общем хранилище требует all-files
         доступа. Приложение ставится сайдлоадом, ограничение Play на это
         разрешение неприменимо. По умолчанию шара лежит в папке приложения и
         разрешение не нужно; запрашиваем (через системные Настройки) только при
         выборе своей папки. Android 11+. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Trusted-network auto-pause (task 3b-2): reading the current Wi-Fi SSID.
         FINE_LOCATION is the cross-version path that unredacts the SSID in
         NetworkCapabilities (API 29+); on Android 13+ NEARBY_WIFI_DEVICES is
         the modern companion. Requested at runtime; the feature degrades
         gracefully (never auto-pauses) when the user declines. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />

    <application
        android:name=".XrApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.XrProxy">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.XrProxy">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- HTTPS invite links от любого self-hosted xr-hub:
                 не используем autoVerify (нет assetlinks.json у клиентских доменов). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:pathPrefix="/invite/" />
            </intent-filter>

            <!-- Custom-схема для ручных deep-link'ов. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="xr" android:host="invite" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.XrVpnService"
            android:exported="false"
            android:foregroundServiceType="systemExempted|location"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
